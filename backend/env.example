# Environment variables for HabitBuddy API
# Copy this file to .env and fill in your values

# Database Configuration
# PostgreSQL is required. Copy this line into your `.env` and update credentials
# Example:
# DATABASE_URL=postgresql://username:password@localhost:5432/habitbuddy
DATABASE_URL=postgresql://dev:dev123@localhost:5432/habitbuddy

# Mode Configuration
# PROD_MODE=false means dev mode (like Angular's production: false)
# PROD_MODE=true means production mode
PROD_MODE=false

# For production with PostgreSQL
# DATABASE_URL=postgresql://username:password@host:port/database_name

# Firebase Configuration
# Path to Firebase service account key file (for local development)
# FIREBASE_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json
# Or set GOOGLE_APPLICATION_CREDENTIALS environment variable

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:4200,https://abhyatus.web.app,https://abhyatus.firebaseapp.com
